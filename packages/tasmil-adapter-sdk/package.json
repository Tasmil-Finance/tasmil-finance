{
  "name": "@tasmil/adapter-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@allbridge/bridge-core-sdk": "^3.30.0",
    "@blend-capital/blend-sdk": "^3.2.2",
    "@stellar/stellar-sdk": "^15.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsc-alias": "^1.8.10",
    "typescript": "5.5.4",
    "vitest": "^2.1.0"
  }
}
